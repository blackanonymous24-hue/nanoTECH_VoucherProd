{
  "expo": {
    "name": "nanoTECH Vouchers",
    "slug": "nanotech-vouchers-bills",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nanotech",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nanotech.vouchers"
    },
    "android": {
      "package": "com.nanotech.vouchers",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-splash-screen"
    ],
    "extra": {
      "webAppUrl": "https://nanovoucher.com",
      "eas": {
        "projectId": "12fb732a-dfe0-48e8-b8a5-e89ffc872705"
      }
    },
    "owner": "skongnon"
  }
}
