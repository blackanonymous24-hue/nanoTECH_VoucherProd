{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local",
    "requireCommit": false
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_MONOREPO_ROOT": "../../",
        "NODE_ENV": "development"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_MONOREPO_ROOT": "../../",
        "NODE_ENV": "development"
      }
    }
  }
}
