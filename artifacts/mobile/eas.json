{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local",
    "requireCommit": false
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "env": {
        "EXPO_MONOREPO_ROOT": "../../",
        "NODE_ENV": "production",
        "EXPO_ROUTER_APP_ROOT": "/home/expo/workingdir/build/artifacts/mobile/app",
        "EXPO_ROUTER_IMPORT_MODE": "sync",
        "EXPO_PUBLIC_WEB_APP_URL": "https://nanovoucher.com"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_MONOREPO_ROOT": "../../",
        "NODE_ENV": "production",
        "EXPO_ROUTER_APP_ROOT": "/home/expo/workingdir/build/artifacts/mobile/app",
        "EXPO_ROUTER_IMPORT_MODE": "sync",
        "EXPO_PUBLIC_WEB_APP_URL": "https://nanovoucher.com"
      }
    }
  }
}
