# Copier vers /var/www/vouchernet/.env sur le VPS (chmod 600)
# Ne jamais committer le fichier .env réel.

NODE_ENV=production
PORT=3001

# PostgreSQL sur le même VPS (après deploy/postgres-vps-setup.sh) :
DATABASE_URL=postgresql://vouchernet:VOTRE_MOT_DE_PASSE@127.0.0.1:5432/vouchernet

# Ou Neon (cloud) :
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require

# Obligatoire en production — générer : openssl rand -hex 32
SESSION_SECRET=changez-moi-avec-openssl-rand-hex-32

# Optionnel — charge MikroTik / perf (1000+ utilisateurs)
# PG_POOL_MAX=25
# MIK_GLOBAL_MAX_CONCURRENT=32
# MIK_POLLER_INTERVAL_MS=10000
# USER_RECONCILE_MIN_MS=30000
# ROUTER_MIN_GAP_MS=500
# VENDOR_SYNC_INTERVAL_MS=12000
# AUTO_BYPASS_SYNC_INTERVAL_MS=60000
# LOG_LEVEL=info
