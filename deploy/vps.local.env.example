# Copier ce fichier vers deploy/vps.local.env (ignoré par Git).
#   copy deploy\vps.local.env.example deploy\vps.local.env
#
# Recommandé : authentification par clé SSH (pas de mot de passe en clair).
# Une fois la clé installée sur le VPS, le script deploy-local.ps1 pourra
# lancer la mise à jour sans vous redemander le mot de passe.

VPS_HOST=69.62.110.53
VPS_USER=root
VPS_PORT=22

# Chemin vers votre clé privée SSH (Windows : C:\Users\Vous\.ssh\id_ed25519)
VPS_SSH_KEY=

# Optionnel — déconseillé : mot de passe SSH (nécessite sshpass sous WSL/Git Bash)
# VPS_SSH_PASSWORD=

# Dossier de l'app sur le serveur
VPS_APP_DIR=/var/www/vouchernet

# Branche Git déployée sur le VPS
VOUCHERNET_BRANCH=main
