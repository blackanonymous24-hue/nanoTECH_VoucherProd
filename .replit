modules = ["nodejs-24", "javascript", "python-3.11", "postgresql-16"]
run = ["sh", "-c", "corepack enable && pnpm install && (PORT=${VITE_PORT:-23863} pnpm --filter @workspace/app run dev &) && VITE_PORT=${VITE_PORT:-23863} pnpm --filter @workspace/api-server run dev"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["sh", "-c", "corepack enable && pnpm install && pnpm --filter @workspace/app run build && pnpm --filter @workspace/api-server run build"]
run = ["sh", "-c", "corepack enable && pnpm --filter @workspace/api-server run start"]

[deployment.postBuild]
args = ["sh", "-c", "corepack enable && pnpm store prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
COREPACK_HOME = "/tmp/corepack"
COREPACK_ENABLE_STRICT = "0"
